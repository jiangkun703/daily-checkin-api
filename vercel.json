{
  "version": 2,
  "builds": [
    {
      "src": "vercel/api/**/*.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "vercel/simple-demo.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/vercel/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/vercel/$1"
    },
    {
      "src": "/",
      "dest": "/vercel/simple-demo.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["hkg1"],
  "functions": {
    "vercel/api/simple.js": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "github": {
    "silent": true
  }
}